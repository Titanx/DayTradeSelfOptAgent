# AStockAgent 环境变量配置

# === LLM 配置 ===
# 优先使用 DeepSeek（国内速度快，便宜）
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 其他LLM提供商（可选）
# OPENAI_API_KEY=your_openai_api_key
# ANTHROPIC_API_KEY=your_anthropic_api_key
# DASHSCOPE_API_KEY=your_dashscope_api_key  # 通义千问

# === AStockAgent 配置 ===
# ASTOCK_LLM_PROVIDER=deepseek
# ASTOCK_DEEP_THINK_LLM=deepseek-chat
# ASTOCK_QUICK_THINK_LLM=deepseek-chat
# ASTOCK_DATA_VENDOR=akshare
# ASTOCK_MAX_DEBATE_ROUNDS=1
# ASTOCK_MAX_RISK_ROUNDS=1
# ASTOCK_DEBUG=true

# === Tushare 数据（可选） ===
# TUSHARE_TOKEN=your_tushare_token
